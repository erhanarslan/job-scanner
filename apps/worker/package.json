    "@job-scanner/database": "workspace:*",
    "@job-scanner/scoring": "workspace:*",
    "@job-scanner/shared": "workspace:*",
    "@job-scanner/validation": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
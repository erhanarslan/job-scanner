{
  "name": "job-scanner",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @job-scanner/api dev",
    "dev:worker": "pnpm --filter @job-scanner/worker dev",
    "dev:web": "pnpm --filter @job-scanner/web dev",
    "dev:mobile": "pnpm --filter @job-scanner/mobile dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @job-scanner/database generate",
    "db:migrate": "pnpm --filter @job-scanner/database migrate",
    "db:push": "pnpm --filter @job-scanner/database push",
    "db:studio": "pnpm --filter @job-scanner/database studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3",
    "turbo": "^2.0.0",
    "typescript": "^5.5.4"
  }
}